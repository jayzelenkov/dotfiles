{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

echo "=========================================="
echo "  macOS Bootstrap (chezmoi run_once)"
echo "=========================================="
echo ""

# Authenticate once and share that session across all subprocesses.
#
# By default macOS sudo uses per-TTY tickets (tty_tickets), so brew's internal
# sudo calls — which run in subprocess contexts — each prompt separately.
# We temporarily disable tty_tickets and extend the timeout for this user so
# that the single sudo -v below covers the entire install. The sudoers file is
# removed on exit.
echo "→ Requesting sudo access (you'll only be asked once)..."
sudo -v

SUDOERS_BOOTSTRAP=/etc/sudoers.d/chezmoi-bootstrap
printf 'Defaults:%s !tty_tickets\nDefaults:%s timestamp_timeout=120\n' "$USER" "$USER" \
    | sudo tee "$SUDOERS_BOOTSTRAP" > /dev/null
sudo chmod 440 "$SUDOERS_BOOTSTRAP"
trap 'sudo rm -f "$SUDOERS_BOOTSTRAP" 2>/dev/null || true' EXIT
echo ""

# Xcode Command Line Tools
if xcode-select -p &>/dev/null; then
    echo "✓ Xcode Command Line Tools already installed"
else
    echo "→ Installing Xcode Command Line Tools..."
    xcode-select --install
    echo "  Waiting for Xcode CLI tools installation..."
    until xcode-select -p &>/dev/null; do
        sleep 5
    done
    echo "✓ Xcode Command Line Tools installed"
fi
echo ""

# Homebrew
if command -v brew &>/dev/null; then
    echo "✓ Homebrew already installed"
else
    echo "→ Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [[ -f "/opt/homebrew/bin/brew" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    echo "✓ Homebrew installed"
fi

echo "→ Updating Homebrew..."
brew update
echo "✓ Homebrew updated"
echo ""

# Install mas first so App Store entries work in brew bundle
if ! command -v mas &>/dev/null; then
    brew install mas
fi

# Add taps before bundle so formula names resolve correctly
brew tap nikitabobko/tap 2>/dev/null || true
brew tap FelixKratz/formulae 2>/dev/null || true
brew tap hedhyw/main 2>/dev/null || true

# Install all packages from Brewfile
echo "→ Installing packages from Brewfile..."
echo "  (This may take a while)"
echo ""
if brew bundle --file=/dev/stdin <<EOF
{{ include "Brewfile" }}
EOF
then
    echo ""
    echo "✓ All packages installed"
else
    echo ""
    echo "⚠️  Some packages failed to install. Run 'brew bundle --file=<Brewfile>' to retry."
fi
{{ end -}}
