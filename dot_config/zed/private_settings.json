// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ---------- Fonts & UI ----------
  "buffer_font_family": "Hack Nerd Font Mono",
  "buffer_font_size": 16,
  "ui_font_size": 16,
  "terminal": {
    "font_family": "Hack Nerd Font Mono",
    "font_size": 14,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "project_panel": {
    "dock": "right",
  },

  // ---------- Editor (ported from VSCode) ----------
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_wrap_guides": true,
  "wrap_guides": [80, 100],
  "show_whitespaces": "all",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "cursor_blink": false,
  "cursor_shape": "bar",
  "unicode_ambiguous_characters_highlight": false,
  "file_types": {
    "SQL": ["sdl"],
  },

  // ---------- Inline AI suggestions ----------
  "edit_predictions": {
    "provider": "zed",
  },

  // ---------- Telemetry ----------
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },

  // ---------- Claude Code as default external agent ----------
  // Zed bundles its own Claude Code adapter; override to use your local CLI
  // so MCP servers, plugins, and updates managed via ~/.claude/ are shared.
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/Users/jzelenkov/.local/bin/claude",
      },
    },
  },

  // ---------- Built-in Zed Agent (used if you open it instead of Claude Code) ----------
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-7-sonnet-latest",
    },
  },

  // ---------- Language-specific formatters (mirror VSCode prettier defaults) ----------
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "JSON": {
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "HTML": {
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "Python": {
      "tab_size": 4,
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "Java": {
      "format_on_save": "on",
    },
  },
}
